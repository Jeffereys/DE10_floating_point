module full_adder_subtractor_1bit (
    input logic clk,
    input  logic A,       // Input bit A
    input  logic B,       // Input bit B
    input  logic cin,     // Carry in (for addition) or borrow in (for subtraction)
    input  logic add_sub, // Control signal: 0 for Add, 1 for Subtract
    output logic sum,     // Sum or difference result
    output logic G,       // Generate signal
    output logic P        // Propagate signal
);

    logic B_complement;   // B XOR-ed for subtraction

    // XOR B with add_sub to perform subtraction when add_sub is 1
    assign B_complement = B ^ add_sub;

    // Generate and Propagate signals
    assign G = A & B_complement;  // Generate G = A & B_complement
    assign P = A ^ B_complement;  // Propagate P = A ^ B_complement
    
    // Sum calculation
    assign sum = P ^ cin;         // Sum = P XOR carry-in

endmodule
