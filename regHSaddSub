////////////////------------------------------------------------------------------------------------------////////////////////////////////////
module cla_4bit (
    input  logic [3:0] A,        // 4-bit Input A
    input  logic [3:0] B,        // 4-bit Input B
    input  logic       cin,      // Carry-in (for LSB)
    input  logic       add_sub,  // Control signal: 0 for Add, 1 for Subtract
    output logic [3:0] sum,      // 4-bit Sum or Difference
    output logic       carry_out_1 // Carry-out from the MSB
);

    logic [3:0] G, P;            // Generate and Propagate signals
    logic [3:0] C;               // Carry signals

    // Instantiate 1-bit full adder/subtractor units
    full_adder_subtractor_1bit fa0 (.A(A[0]), .B(B[0]), .cin(cin), .add_sub(add_sub), .sum(sum[0]), .G(G[0]), .P(P[0]));
    full_adder_subtractor_1bit fa1 (.A(A[1]), .B(B[1]), .cin(C[0]), .add_sub(add_sub), .sum(sum[1]), .G(G[1]), .P(P[1]));
    full_adder_subtractor_1bit fa2 (.A(A[2]), .B(B[2]), .cin(C[1]), .add_sub(add_sub), .sum(sum[2]), .G(G[2]), .P(P[2]));
    full_adder_subtractor_1bit fa3 (.A(A[3]), .B(B[3]), .cin(C[2]), .add_sub(add_sub), .sum(sum[3]), .G(G[3]), .P(P[3]));

    // Carry-lookahead logic
    assign C[0] = G[0] | (P[0] & cin);        // Carry-in to second bit
    assign C[1] = G[1] | (P[1] & C[0]);       // Carry-in to third bit
    assign C[2] = G[2] | (P[2] & C[1]);       // Carry-in to fourth bit
    assign carry_out_1 = G[3] | (P[3] & C[2]);  // Carry-out from the MSB

endmodule
