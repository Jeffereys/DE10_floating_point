////////////////------------------------------------------------------------------------------------------////////////////////////////////////
module regHSaddSub (
    input  logic [7:0] Sw,       // 8-bit Input A -or- B
    input  logic       SwitchAB, // Switch between A or B inputs
    input  logic       add_sub,  // Control signal: 0 for Add, 1 for Subtract
    input  logic       clk,      // Clock signal
    input  logic       rst_n,    // Asynchronous active-low reset
    output logic [7:0] result,   // 8-bit result of the operation
    output logic       carry_out,// Carry out flag
    output logic       overflow, // Overflow flag
    output logic       zero,     // Zero flag
    output logic       negative  // Negative flag
);

    logic [7:0] A, B;            // 8-bit Input A and B
    logic carry_in_lsb, carry_out_lsb, carry_out_msb;  // Carry signals between the CLA blocks
    logic [7:0] sum;                                   // Sum of 8 bits

    // Carry-in for the LSB CLA block is add_sub for subtraction, 0 for addition
    assign carry_in_lsb = add_sub;

    // Instantiate two 4-bit CLA blocks for the lower and upper 4 bits
    cla_4bit cla_lower (
        .A(A[3:0]), .B(B[3:0]), .cin(carry_in_lsb), .add_sub(add_sub),
        .sum(sum[3:0]), .carry_out_1(carry_out_lsb)
    );
    cla_4bit cla_upper (
        .A(A[7:4]), .B(B[7:4]), .cin(carry_out_lsb), .add_sub(add_sub),
        .sum(sum[7:4]), .carry_out_1(carry_out_msb)
    );

    // Switch between A or B inputs based on SwitchAB signal
    always_ff @(posedge clk ) begin
        if (!rst_n) begin
            A <= 8'b0;
            B <= 8'b0;
        end else begin
            if (!SwitchAB) begin
                A <= Sw;  // Use Sw for A
            end else begin
                B <= Sw;  // Use Sw for B
            end
        end
    end

    // Register the result and condition codes on the clock edge
    always_ff @(posedge clk) begin
        if (!rst_n) begin
            result    <= 8'b0;
            carry_out <= 1'b0;
            overflow  <= 1'b0;
            zero      <= 1'b0;
            negative  <= 1'b0;
        end else begin
            result    <= sum;
            carry_out <= carry_out_msb;               // Carry-out from the most significant bit
            overflow  <= carry_out_lsb ^ carry_out_msb;  // Overflow detection based on carry into and out of MSB
            zero      <= (sum == 8'b0);               // Zero flag: all result bits are 0
            negative  <= sum[7];                      // Negative flag: MSB of the result
        end
    end

endmodule
